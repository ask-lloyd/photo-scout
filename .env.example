# PhotoScout Environment Variables
# Copy to .env.local for local development

# ─── Cron Auth ───
# Bearer token for Vercel Cron endpoints (/api/cron/*)
# If unset, cron endpoints are unauthenticated (fine for local dev)
CRON_SECRET=

# ─── Cloudflare R2 (User Profile Storage) ───
# When all three R2_* vars are set, storage uses R2.
# When unset, falls back to local filesystem (~/.photoscout/)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com

# Optional: R2 bucket name (default: "photoscout-profiles")
# R2_BUCKET=photoscout-profiles

# ─── Notes ───
# No API keys needed for weather data — Open-Meteo is free and keyless.
# No API keys needed for sun/moon calculations — suncalc runs client-side.
